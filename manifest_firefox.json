{
  "manifest_version": 2,
  "name": "RecMan PoliMi – Link Webex",
  "version": "1.5",
  "description": "Estrae automaticamente i link Webex dalla pagina RecMan del PoliMi.",
  "browser_specific_settings": {
    "gecko": {
      "id": "recman-polimi@extension",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "webRequest",
    "storage",
    "tabs",
    "*://*.polimi.it/*",
    "*://politecnicomilano.webex.com/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["*://*.polimi.it/recman_frontend/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
